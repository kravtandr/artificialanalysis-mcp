# Ключ Artificial Analysis Data API (обязателен): https://artificialanalysis.ai/api-key-management-redirect
ARTIFICIAL_ANALYSIS_API_KEY=

# Bearer-токен для /mcp (обязателен при запуске через docker compose).
# Сгенерировать: openssl rand -hex 24
MCP_AUTH_TOKEN=

# Порт на хосте для docker compose (проброшен только на 127.0.0.1)
# MCP_PORT=3000

# Необязательные настройки (значения по умолчанию — см. SPEC.md §5)
# AA_CACHE_TTL_SECONDS=21600
# AA_REQUEST_TIMEOUT_MS=30000
# MCP_TRANSPORT=stdio
# MCP_HTTP_HOST=127.0.0.1
# PORT=3000
# LOG_LEVEL=info
